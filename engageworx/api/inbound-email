// /api/inbound-email.js — SendGrid Inbound Parse webhook handler
// Receives inbound emails, stores in Supabase, triggers AI reply

const { createClient } = require('@supabase/supabase-js');

const supabase = createClient(
  process.env.REACT_APP_SUPABASE_URL,
  process.env.SUPABASE_SERVICE_ROLE_KEY
);

const EW_SP_TENANT_ID = 'c1bc59a8-5235-4921-9755-02514b574387';

module.exports = async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  if (req.method === 'OPTIONS') return res.status(200).end();
  if (req.method !== 'POST') return res.status(405).json({ error: 'POST only' });

  try {
    // SendGrid Inbound Parse sends multipart/form-data
    const from = req.body.from || '';
    const to = req.body.to || '';
    const subject = req.body.subject || '(no subject)';
    const text = req.body.text || '';
    const html = req.body.html || '';
    const body = text || html.replace(/<[^>]*>/g, '') || '';

    // Extract sender email
    const fromEmail = from.match(/[\w.-]+@[\w.-]+\.\w+/)?.[0] || from;
    const fromName = from.replace(/<.*>/, '').trim() || fromEmail;

    // Determine which tenant this email belongs to based on recipient
    const toEmail = to.match(/[\w.-]+@[\w.-]+\.\w+/)?.[0] || '';
    
    // Find tenant by email address in channel_configs
    let tenantId = EW_SP_TENANT_ID;
    try {
      const { data: configs } = await supabase
        .from('channel_configs')
        .select('tenant_id, config_encrypted')
        .eq('channel', 'email');
      
      if (configs) {
        for (const config of configs) {
          const cfg = config.config_encrypted || {};
          if (cfg.inbound_email && toEmail.includes(cfg.inbound_email.split('@')[0])) {
            tenantId = config.tenant_id;
            break;
          }
        }
      }
    } catch(e) { console.log('[inbound-email] tenant lookup error:', e.message); }

    // Find or create conversation
    let conversationId;
    const { data: existing } = await supabase
      .from('conversations')
      .select('id')
      .eq('contact_phone', fromEmail)
      .eq('tenant_id', tenantId)
      .eq('channel', 'email')
      .order('created_at', { ascending: false })
      .limit(1)
      .single();

    if (existing) {
      conversationId = existing.id;
      await supabase.from('conversations').update({
        last_message: body.substring(0, 200),
        last_message_at: new Date().toISOString(),
        unread_count: supabase.rpc('increment', { x: 1 }),
        status: 'open',
      }).eq('id', conversationId);
    } else {
      const { data: newConv } = await supabase.from('conversations').insert({
        tenant_id: tenantId,
        contact_name: fromName,
        contact_phone: fromEmail,
        channel: 'email',
        status: 'open',
        last_message: body.substring(0, 200),
        last_message_at: new Date().toISOString(),
        unread_count: 1,
        metadata: { subject, to: toEmail },
      }).select().single();
      conversationId = newConv?.id;
    }

    // Store message
    if (conversationId) {
      await supabase.from('messages').insert({
        conversation_id: conversationId,
        tenant_id: tenantId,
        direction: 'inbound',
        channel: 'email',
        from_address: fromEmail,
        to_address: toEmail,
        body: body.substring(0, 5000),
        metadata: { subject, html: html.substring(0, 5000) },
        created_at: new Date().toISOString(),
      });
    }

    // AI auto-reply
    try {
      const aiRes = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': process.env.ANTHROPIC_API_KEY,
          'anthropic-version': '2023-06-01',
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 500,
          messages: [{
            role: 'user',
            content: `You are a helpful customer service assistant. Reply to this email professionally and concisely.\n\nFrom: ${fromName}\nSubject: ${subject}\nMessage: ${body}\n\nWrite a helpful reply. Be warm, professional and brief.`
          }],
        }),
      });

      const aiData = await aiRes.json();
      const aiReply = aiData.content?.[0]?.text;

      if (aiReply) {
        // Store AI reply as outbound message
        if (conversationId) {
          await supabase.from('messages').insert({
            conversation_id: conversationId,
            tenant_id: tenantId,
            direction: 'outbound',
            channel: 'email',
            from_address: toEmail,
            to_address: fromEmail,
            body: aiReply,
            metadata: { subject: 'Re: ' + subject, ai_generated: true },
            created_at: new Date().toISOString(),
          });
        }

        // Send AI reply via SendGrid
        await fetch('https://api.sendgrid.com/v3/mail/send', {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${process.env.SENDGRID_API_KEY}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            personalizations: [{ to: [{ email: fromEmail }] }],
            from: { email: toEmail || 'hello@engwx.com', name: 'EngageWorx' },
            subject: 'Re: ' + subject,
            content: [{ type: 'text/plain', value: aiReply }],
          }),
        });
      }
    } catch(aiErr) {
      console.log('[inbound-email] AI reply error:', aiErr.message);
    }

    return res.status(200).json({ success: true });
  } catch (err) {
    console.error('[inbound-email] Error:', err);
    return res.status(500).json({ error: err.message });
  }
};
