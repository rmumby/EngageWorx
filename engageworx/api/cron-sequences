// /api/cron-sequences.js — Daily sequence processor
// Called by Vercel cron job
// Default: 9am ET (14:00 UTC) — configurable via SEQUENCE_CRON_HOUR env var

module.exports = async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  if (req.method === 'OPTIONS') return res.status(200).end();

  // Security: only allow GET from Vercel cron or POST with secret
  var authHeader = req.headers['authorization'];
  var cronSecret = process.env.CRON_SECRET;
  if (cronSecret && authHeader !== 'Bearer ' + cronSecret) {
    // Allow Vercel internal cron calls (no auth header)
    if (req.headers['x-vercel-cron'] !== '1' && authHeader) {
      return res.status(401).json({ error: 'Unauthorized' });
    }
  }

  try {
    // Call the sequences process action
    var baseUrl = process.env.VERCEL_URL
      ? 'https://' + process.env.VERCEL_URL
      : 'https://portal.engwx.com';

    var response = await fetch(baseUrl + '/api/sequences?action=process', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
    });

    var data = await response.json();
    console.log('[Cron] Sequences processed:', data);

    return res.status(200).json({
      success: true,
      timestamp: new Date().toISOString(),
      ...data,
    });
  } catch (err) {
    console.error('[Cron] Error:', err.message);
    return res.status(500).json({ error: err.message });
  }
};
